{
  "$schema": "design-tokens-draft",
  "name": "TechCircle Design System",
  "source": ["techcircle-v6_3.html", "techcircle-v5_7.html"],
  "color": {
    "text": {
      "heading": { "value": "#030407" },
      "primary": { "value": "#161618" },
      "caption": { "value": "#445372" }
    },
    "brand": {
      "blue": { "value": "#0069ff", "usage": "links, authors, focus" },
      "mint": { "value": "#f99d1c", "usage": "orange accent bar, hovers, poll fill" },
      "mint600": { "value": "#c47b14", "usage": "accessible orange text on white" }
    },
    "surface": {
      "default": { "value": "#ffffff" },
      "border": { "value": "#e0e2e7" },
      "gray100": { "value": "#f0f1f3" },
      "neutral200": { "value": "#eaecf0", "usage": "secondary nav" },
      "hoverFill": { "value": "#f6f7f9" }
    },
    "header": {
      "bg": { "value": "#000000" },
      "search": { "value": "#333333" },
      "navy": { "value": "#11255e" },
      "navyHover": { "value": "#19337f" }
    },
    "dark": {
      "0": { "value": "#0b0f14" },
      "1": { "value": "#0f172a" },
      "2": { "value": "#111827" },
      "hover": { "value": "#13203a" },
      "border": { "value": "#242a46" },
      "authorOnDark": { "value": "#9eb4ff" },
      "authorOnDarkAlt": { "value": "#93c5fd" },
      "dateOnDark": { "value": "#c7cdda" },
      "dateOnDarkAlt": { "value": "#94a3b8" },
      "mutedOnDark": { "value": "#cbd5e1" },
      "mutedOnDark2": { "value": "#8a93a6" }
    },
    "band": {
      "video": { "value": "#e5f5e5" },
      "videoCard": { "value": "#eff5ef" },
      "videoCardHover": { "value": "#e6efe6" },
      "events": { "value": "#f4f0e8" },
      "eventsCard": { "value": "#fbf8f1" },
      "eventsFill": { "value": "#efe8da" },
      "eventsBorderHover": { "value": "#d9cfbb" },
      "imgPlaceholder": { "value": "#ded5c4" }
    }
  },
  "typography": {
    "families": {
      "body": { "value": "'Inter', system-ui, -apple-system, sans-serif" },
      "heading": { "value": "'Young Serif', Georgia, 'Times New Roman', serif", "weight": 400 },
      "mono": { "value": "'IBM Plex Mono', monospace", "usage": "meta, badges, secondary nav, buttons" },
      "nav": { "value": "'Poppins', sans-serif", "usage": "primary nav, dropdowns" },
      "logo": { "value": "'Lato', sans-serif", "weight": 800 }
    },
    "scale": {
      "sectionH2": { "desktop": 40, "mobile": 24, "letterSpacing": -1 },
      "heroH2": { "desktop": [36, 42], "mobile": 24 },
      "cardH3": { "desktop": 24, "mobile": 20, "letterSpacing": 0.4 },
      "listH3": { "desktop": [18, 22] },
      "pollQuestion": { "desktop": 32, "mobile": 22 },
      "body": { "size": 16, "lineHeight": 1.6 },
      "meta": { "size": 13 },
      "badge": { "size": 12, "letterSpacing": 1.44, "transform": "uppercase" },
      "navLink": { "size": 15, "weight": 500, "transform": "uppercase" },
      "snavLink": { "size": 14, "weight": 500, "transform": "uppercase" }
    }
  },
  "layout": {
    "maxWidth": 1440,
    "contentWidth": 1280,
    "gutters": { "xl": 0, "lg": 40, "md": 24, "sm": 16 },
    "gap": 24,
    "sectionPaddingTop": { "desktop": 110, "mobile": 36 },
    "bandPadding": { "desktop": 80, "mobile": 44 },
    "breakpoints": [1279, 1200, 1024, 900, 860, 560, 380]
  },
  "shape": {
    "radius": 0,
    "radiusPlayBadge": "50%",
    "hairline": "1px solid #e0e2e7",
    "accentBarWidth": 3
  },
  "shadow": {
    "dropdown": "0 12px 30px rgba(0,0,0,.18)",
    "secondaryNav": "0 12px 30px rgba(0,0,0,.16)",
    "drawer": "-12px 0 30px rgba(0,0,0,.3)",
    "heroV3": "0 10px 28px -10px rgba(0,0,0,.08)",
    "eventCardHover": "0 10px 28px -12px rgba(0,0,0,.18)"
  },
  "motion": {
    "fast": ".2s ease",
    "medium": ".35s ease",
    "drawer": ".25s ease",
    "pollFill": ".8s cubic-bezier(.22,.61,.36,1)",
    "imageZoomCard": 1.05,
    "imageZoomThumb": 1.08,
    "hoverUnderline": { "offset": 3, "thickness": 1.5 },
    "reducedMotion": "all card transitions disabled"
  },
  "gradients": {
    "imageShade": "linear-gradient(to bottom, rgba(0,0,0,0) 40%, rgba(0,0,0,.9) 92%)",
    "podHeroShade": "linear-gradient(to bottom, rgba(0,0,0,0) 20%, #000 84.6%)",
    "darkPanel": "linear-gradient(180deg, #0b0f14, #111827)"
  },
  "fontsImport": "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Poppins:wght@400;500;600&family=Lato:wght@700;800;900&family=Young+Serif&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
}
